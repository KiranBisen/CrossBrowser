<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Browser Execution" parallel="tests" thread-count="5"> 
  <test name="Chrome Test">
  <parameter name="browsers" value="chrome"></parameter>
    <classes>
      <class name="crossbrowser.cross"/>
    </classes>
  </test> 
  
   <test name="Firefox Test">
  <parameter name="browsers" value="firefox"></parameter>
    <classes>
      <class name="crossbrowser.cross"/>
    </classes>
  </test> 
  
   <test name="Edge Test">
  <parameter name="browsers" value="edge"></parameter>
    <classes>
      <class name="crossbrowser.cross"/>
    </classes>
  </test> 
  
</suite> <!-- Suite -->
